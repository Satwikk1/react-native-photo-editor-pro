{
  "name": "react-native-photo-editor-pro",
  "version": "0.1.0",
  "description": "A high-performance photo editor for React Native using Skia",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.tsx",
  "source": "src/index.tsx",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!lib/typescript/example",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "bob build",
    "prepare": "bob build || echo 'Skipping prepare'",
    "watch": "bob build --watch"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "skia",
    "photo-editor",
    "image-processing",
    "reanimated",
    "gestures",
    "filters",
    "cropping",
    "markup"
  ],
  "repository": "https://github.com/satwikk/react-native-photo-editor-pro",
  "author": "Satwikk <satwikk@example.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/satwikk/react-native-photo-editor-pro/issues"
  },
  "homepage": "https://github.com/satwikk/react-native-photo-editor-pro#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.73.1",
    "@shopify/react-native-skia": "^2.4.18",
    "@types/jest": "^29.5.5",
    "@types/react": "~19.2.0",
    "del-cli": "^5.1.0",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.23.2",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=0.1.0",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3.0.0",
    "react-native-gesture-handler": ">=2.0.0"
  },
  "workspaces": [
    "example"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}